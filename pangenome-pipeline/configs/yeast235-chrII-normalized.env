# Config: yeast-235 chrII 100kb normalized graph
# Sourced by run.sh — all paths resolved relative to $MEM_PROJ (mem-projection root).

# ---- Inputs ---------------------------------------------------------------
GBZ="$MEM_PROJ/yeast-235/yeast-235-chrI/final_output2/yeast235_chrII_100kb_laced_sorted_normalized.gbz"
GFA="$MEM_PROJ/yeast-235/yeast-235-chrI/final_output2/yeast235_chrII_100kb_laced_sorted_normalized_new.gfa"
READS="$MEM_PROJ/yeast-235/yeast-235-chrI/S288C_chrII_N100K_R1_200_reads.txt"

# ---- Naming ---------------------------------------------------------------
# BASE prefixes index files (.seq .rl_bwt .ri .tags _compressed.tags .paths)
# OUT  prefixes find_mems / gafpack outputs (_path_pos.bin _seq_id_starts.out .gaf _coverage.csv)
BASE="yeast235_chrII_100kb_normalized"
OUT="S288C_chrII_N100K_R1_200_normalized"

# ---- Pipeline parameters --------------------------------------------------
KMER=31
MEM_LEN=30
MIN_OCC=1
THREADS=16
VALIDATE_SAMPLE=2000

# ---- Reference run for compare.sh (optional) ------------------------------
# Directory containing a known-good prior run; compare.sh will md5/size-diff
# this run's outputs against it. Leave empty to skip.
REF_DIR="$MEM_PROJ/yeast-235/yeast-235-chrI/final_output2"
# Map BASE/OUT names in REF_DIR if they differ from this config's:
REF_BASE="yeast235_chrII_100kb_normalized"
REF_OUT="S288C_chrII_N100K_R1_200_normalized"
